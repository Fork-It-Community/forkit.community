---
interface Props {
  label: string;
  name: "room" | "type";
  options: Array<{ value: string; label: string }>;
}

const { label, name, options } = Astro.props;
const buttons = [{ value: "__all", label: "All" }, ...options];
---

<div class="flex items-center gap-3">
  <span
    class="w-12 shrink-0 font-heading text-xs uppercase tracking-widest opacity-60"
  >
    {label}
  </span>
  <div
    class="hide-scrollbar flex min-w-0 flex-1 items-center gap-1 overflow-x-auto rounded-lg bg-white/5 p-1"
    role="group"
    aria-label={`Filter schedule by ${name}`}
    data-filter-group={name}
  >
    {
      buttons.map((button) => (
        <button
          type="button"
          class="filter-btn whitespace-nowrap rounded-md px-3 py-1.5 font-heading text-xs uppercase tracking-wider opacity-50 transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/30 aria-pressed:bg-white/15 aria-pressed:opacity-100"
          aria-pressed={button.value === "__all" ? "true" : "false"}
          data-filter-value={button.value}
        >
          {button.label}
        </button>
      ))
    }
  </div>
</div>

<style>
  /* Gate hover to real pointers. On touch devices :hover sticks after a tap,
     which would keep a tapped filter highlighted as if it were selected. The
     selected state comes from aria-pressed, not hover. */
  @media (hover: hover) {
    .filter-btn:not([aria-pressed="true"]):hover {
      background-color: rgb(0 0 0 / 0.3);
      opacity: 1;
    }
  }
</style>
