---
import TiltedCard from "@/components/TiltedCard";
import { buttonVariants } from "@/components/ui/button";
import { getEventWithComputed } from "@/lib/events";
import { cn } from "@/lib/utils-client";

interface Props {
  eventId: string;
}
const { eventId } = Astro.props;

const event = await getEventWithComputed(eventId);
const prospectusHref = event.data.prospectus?.href;
---

<div class="px-6 py-12">
  <TiltedCard client:visible className="mx-auto max-w-screen-md">
    <div
      class="flex flex-col items-start gap-6 rounded-lg bg-white/5 p-8 backdrop-blur-md transition hover:bg-white/10 md:flex-row md:items-center md:justify-between md:px-12 md:py-10"
    >
      <div class="flex flex-col gap-3">
        <h2 class="font-heading text-xl uppercase leading-tight text-primary">
          Want to support the next event?
        </h2>
        <p class="text-sm text-white/80">
          Support the community and make your company shine
        </p>
      </div>
      {
        prospectusHref && (
          <a
            href={prospectusHref}
            target="_blank"
            rel="noreferrer"
            class={cn(
              buttonVariants({ variant: "default" }),
              "w-full md:w-auto md:min-w-48",
            )}
          >
            Become a Sponsor
          </a>
        )
      }
    </div>
  </TiltedCard>
</div>
