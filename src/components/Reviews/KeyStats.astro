---
import StarRating from "@/components/StarRating/index.astro";

interface Stat {
  value: string;
  label: string;
  highlighted?: boolean;
  rating?: boolean;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<section class="mx-auto max-w-screen-lg px-6 py-8 md:py-12">
  <div class="grid grid-cols-2 gap-3 md:auto-cols-fr md:grid-flow-col md:gap-4">
    {
      stats.map((stat) => (
        <div
          class={`flex flex-col items-center justify-center gap-1 rounded-xl px-6 py-8 ${stat.highlighted ? "bg-primary" : "bg-white/5"}`}
        >
          <span
            class={`text-center font-heading text-3xl font-medium md:text-4xl ${stat.highlighted ? "text-black" : "text-primary"}`}
          >
            {stat.value}
          </span>
          {stat.rating && (
            <StarRating
              score={parseFloat(stat.value.replace(",", "."))}
              size="sm"
              class={stat.highlighted ? "text-black" : "text-white"}
            />
          )}
          <span
            class={`text-sm font-medium uppercase tracking-widest ${stat.highlighted ? "text-black" : "text-white"}`}
          >
            {stat.label}
          </span>
        </div>
      ))
    }
  </div>
</section>
