---
import { getEventsCollection, shouldShowProspectus } from "@/lib/events";
// @ts-ignore - used in Astro.redirect, TS cannot detect usage in return statements
import { ROUTES } from "@/routes.gen";
// @ts-ignore - used in Astro.redirect, TS cannot detect usage in return statements
import { lunalink } from "@bearstudio/lunalink";

export const prerender = false;

const { id } = Astro.params;
const events = await getEventsCollection();
const event = events.find((e) => e.id === id);

if (event && shouldShowProspectus(event)) {
  return Astro.redirect(event.data.prospectus.href, 302);
}

return Astro.redirect(lunalink(ROUTES.events[":id"].__path, { id: id! }), 302);
---
