---
import { getEventsCollection, shouldShowProspectus } from "@/lib/events";
import { ROUTES } from "@/routes.gen";
import { lunalink } from "@bearstudio/lunalink";

export async function getStaticPaths() {
  const events = await getEventsCollection();
  return events.map((event) => ({
    params: { id: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;

// @ts-expect-error Astro does not recognize variable usage in Astro.redirect
const redirectUrl = shouldShowProspectus(event)
  ? event.data.prospectus.href
  : lunalink(ROUTES.events[":id"].__path, { id: event.id });

return Astro.redirect(redirectUrl, 302);
---
